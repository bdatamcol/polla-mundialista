generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
}

enum MatchPhase {
  GROUP
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

model User {
  id                  String                @id @default(uuid())
  name                String
  email               String                @unique
  password            String
  // Cédula del participante (única para evitar registros duplicados)
  cedula              String                @unique
  // Parentesco / relación con Town Center (campo libre)
  parentesco          String?
  role                Role                  @default(USER)
  // Estado del usuario: true = activo (puede participar), false = bloqueado
  isActive            Boolean               @default(true)
  blockedAt           DateTime?
  blockReason         String?
  totalPoints         Int                   @default(0)
  exactScores         Int                   @default(0)
  correctWinners      Int                   @default(0)
  finalistPoints      Int                   @default(0)
  predictions         Prediction[]
  finalistPrediction  FinalistPrediction?
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([email])
  @@index([cedula])
  @@index([totalPoints])
  @@index([isActive])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// Predicción de finalistas: el usuario elige qué 4 equipos llegan a
// semifinal y qué 2 equipos llegan a la final.
model FinalistPrediction {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 4 selecciones para semifinalistas (códigos TLA, ej: "ARG", "BRA")
  semifinalist1   String?
  semifinalist2   String?
  semifinalist3   String?
  semifinalist4   String?

  // 2 selecciones para finalistas (códigos TLA)
  finalist1       String?
  finalist2       String?

  // Puntos calculados automáticamente
  semifinalPoints Int      @default(0)
  finalPoints     Int      @default(0)
  totalPoints     Int      @default(0)
  semisCorrect    Int      @default(0)
  finalsCorrect   Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Match {
  id             String       @id @default(uuid())
  externalId     String?      @unique
  homeTeam       String
  homeTeamFull   String?
  homeTeamFlag   String?      // Emoji de bandera
  homeTeamCrest  String?      // URL del escudo del equipo
  homeTeamTla    String?      // Código TLA (ej: COL, ARG)
  homeTeamIso2   String?      // Código ISO 3166-1 alpha-2 para flagcdn
  awayTeam       String
  awayTeamFull   String?
  awayTeamFlag   String?
  awayTeamCrest  String?
  awayTeamTla    String?
  awayTeamIso2   String?      // Código ISO 3166-1 alpha-2 para flagcdn
  group          String
  phase          MatchPhase   @default(GROUP)
  matchDate      DateTime
  status         MatchStatus  @default(PENDING)
  homeGoals      Int?
  awayGoals      Int?
  lastSyncAt     DateTime?
  predictions    Prediction[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([matchDate])
  @@index([status])
  @@index([group])
  @@index([externalId])
  @@index([phase])
}

model Prediction {
  id              String   @id @default(uuid())
  userId          String
  matchId         String
  homeGoals       Int
  awayGoals       Int
  points          Int      @default(0)
  isExactScore    Boolean  @default(false)
  isCorrectWinner Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Prize {
  id          String   @id @default(uuid())
  position    Int
  title       String
  description String
  imageUrl    String?
  conditions  String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position])
}

model PointsConfig {
  id                  String   @id @default(uuid())
  // Puntos por acertar marcador exacto en un partido (uniforme para todas las fases)
  matchPoints         Int      @default(5)
  // Puntos por selección correcta a semifinal
  semifinalistPoints  Int      @default(10)
  // Puntos por selección correcta a final
  finalistPoints      Int      @default(20)
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}
